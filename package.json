{
  "name": "arcads-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run seo:sitemap && npm run seo:rss && npm run seo:check",
    "build": "vite build && node scripts/fix-css-blocking.js && node scripts/precompress.js && node scripts/gen-blog-og.js && node scripts/gen-sitemap.mjs && node scripts/gen-rss.mjs && node -e \"import('fs').then(f=>f.copyFileSync('dist/index.html','dist/404.html'))\"",
    "start": "node server/index.js",
    "lint": "eslint .",
    "seo:audit": "node scripts/seo-audit.mjs",
    "seo:fix-og": "node scripts/seo-audit.mjs --fix",
    "seo:sitemap": "node scripts/gen-sitemap.mjs",
    "seo:rss": "node scripts/gen-rss.mjs",
    "seo:feed-sitemap": "node scripts/seo-feed-sitemap-audit.mjs",
    "seo:server-schema": "node scripts/seo-server-schema-audit.mjs",
    "seo:breadcrumb-coverage": "node scripts/seo-breadcrumb-coverage-audit.mjs",
    "seo:og-images": "node scripts/seo-og-image-audit.mjs",
    "seo:canonical": "node scripts/seo-canonical-audit.mjs",
    "seo:headings": "node scripts/seo-headings-audit.mjs",
    "seo:landing-qa": "node scripts/seo-landing-qa.mjs",
    "seo:images": "node scripts/seo-image-audit.mjs",
    "seo:links": "node scripts/seo-links-audit.mjs",
    "seo:blog-schema": "node scripts/seo-blog-schema-audit.mjs",
    "seo:meta-quality": "node scripts/seo-meta-quality-audit.mjs",
    "seo:meta-quality:strict": "node scripts/seo-meta-quality-audit.mjs --strict",
    "seo:meta-intent": "node scripts/seo-meta-intent-audit.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "framer-motion": "^12.34.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.564.0",
    "nodemailer": "^8.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  }
}
